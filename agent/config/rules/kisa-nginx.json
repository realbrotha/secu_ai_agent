{
  "packId": "kisa-nginx",
  "title": "KISA 기준 Nginx 웹서버 보안 점검",
  "version": "1.0",
  "target": { "kind": ["web"], "product": "nginx" },
  "vars": { "web": { "root": "/etc/nginx" } },
  "requires": ["$web.root/nginx.conf"],

  "checks": [
    {
      "checkId": "1.1",
      "title": "웹 프로세스 권한 제한",
      "category": "1. 접근 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review",
          "params": { "detail": "Nginx 데몬이 root 권한으로 운영되지 않고 로그인이 불가능한 전용 데몬 계정으로 구동되는지 확인 필요. nginx.conf의 user 지시어 계정과 실행 중인 master/worker 프로세스 소유자, 해당 계정의 로그인 shell(/sbin/nologin, /bin/false 여부)을 함께 점검해야 하므로 자동 판정 불가." },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "nginx.conf의 user 지시어를 전용 계정으로 설정하고 /etc/passwd에서 해당 계정의 shell을 /sbin/nologin 또는 /bin/false로 제한하십시오."
    },
    {
      "checkId": "1.2",
      "title": "설정 파일이 있는 디렉터리 권한 관리",
      "category": "1. 접근 관리",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info",
          "params": { "path": "$web.root" },
          "as": "d" },
        { "op": "assert.le", "params": { "value": "$d.mode", "threshold": "0755" } },
        { "op": "assert.equals", "params": { "value": "$d.worldWritable", "expected": false } },
        { "op": "assert.equals", "params": { "value": "$d.groupWritable", "expected": false } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "설정 파일 디렉터리의 소유자를 root 또는 전용 Web Server 계정으로 설정하고 group/other 쓰기 권한을 제거(755 이하)하십시오."
    },
    {
      "checkId": "1.3",
      "title": "설정 파일 권한 관리",
      "category": "1. 접근 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info",
          "params": { "path": "$web.root/nginx.conf" },
          "as": "f" },
        { "op": "assert.le", "params": { "value": "$f.mode", "threshold": "0700" } },
        { "op": "assert.equals", "params": { "value": "$f.groupWritable", "expected": false } },
        { "op": "assert.equals", "params": { "value": "$f.worldWritable", "expected": false } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "nginx 설정 파일의 소유자를 root 또는 전용 계정으로 제한하고 group/other 권한을 제거(600 또는 700 이하)하십시오."
    },
    {
      "checkId": "1.4",
      "title": "디렉터리 리스팅 제거",
      "category": "1. 접근 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "config.web_directives",
          "params": { "product": "nginx", "root": "$web.root/nginx.conf", "rule": "any_line_match", "directive": "autoindex", "regex": "(?i)on" },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "nginx 설정에서 autoindex 지시어를 제거하거나 autoindex off;로 설정하십시오."
    },
    {
      "checkId": "2.1",
      "title": "불필요한 파일 제거",
      "category": "2. 보안 설정",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "fs.find_files",
          "params": { "root": "/usr/share/nginx/html", "name_glob": "index.nginx-debian.html", "type": "f", "maxdepth": 3 },
          "as": "def" },
        { "op": "assert.le", "params": { "value": "$def.count", "threshold": 0 } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "기본 index.html, index.htm, index.nginx-debian.html 파일을 삭제하거나 서비스용 파일로 교체하십시오."
    },
    {
      "checkId": "2.2",
      "title": "링크 사용 금지",
      "category": "2. 보안 설정",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "config.web_directives",
          "params": { "product": "nginx", "root": "$web.root/nginx.conf", "rule": "value_match", "directive": "disable_symlinks", "regex": "(?i)on", "default": "off" },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "nginx 설정에 disable_symlinks on;을 적용하십시오."
    },
    {
      "checkId": "2.3",
      "title": "에러 메시지 관리",
      "category": "2. 보안 설정",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review",
          "params": { "detail": "400, 401, 403, 404, 500 에러 코드에 대한 error_page 핸들링 설정 존재 여부와 지정된 에러 페이지 파일의 실제 존재 여부를 함께 확인해야 하므로 자동 판정 불가. error_page 지시어 목록과 문서 루트 내 페이지 파일을 수동 점검하십시오." },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "error_page 400 401 403 404 /custom_40x.html; 및 error_page 500 /custom_50x.html; 등 별도 에러 페이지를 설정하십시오."
    },
    {
      "checkId": "2.4",
      "title": "WebDAV 설정 제한",
      "category": "2. 보안 설정",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "config.web_directives",
          "params": { "product": "nginx", "root": "$web.root/nginx.conf", "rule": "any_line_match", "directive": "dav_methods", "regex": "(?i)(put|delete|mkcol|copy|move)" },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "location /webdav 블록을 제거하거나 dav_methods off; 또는 허용 메서드 제한을 적용하십시오. (참고: 라이브 OPTIONS 응답의 Allow 헤더는 증적용이며, 판정은 dav_methods 지시어 기준입니다.)"
    },
    {
      "checkId": "2.5",
      "title": "응답 메시지 헤더 정보 숨기기",
      "category": "2. 보안 설정",
      "severity": "low",
      "reference": { "kisaRisk": "하" },
      "method": "ops",
      "steps": [
        { "op": "config.web_directives",
          "params": { "product": "nginx", "root": "$web.root/nginx.conf", "rule": "value_match", "directive": "server_tokens", "regex": "(?i)off", "default": "on" },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "http 블록에 server_tokens off;를 설정하십시오. (참고: 라이브 Server 응답 헤더는 증적용이며, 판정은 server_tokens 지시어 기준입니다.)"
    },
    {
      "checkId": "3.1",
      "title": "Web 로그 설정",
      "category": "3. 로그 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "config.web_directives",
          "params": { "product": "nginx", "root": "$web.root/nginx.conf", "rule": "value_match", "directive": "log_format", "regex": "(?is)remote_addr.*status.*http_user_agent" },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "log_format combined에 $remote_addr, $remote_user, $time_local, $request, $status, $body_bytes_sent, $http_referer, $http_user_agent, $http_x_forwarded_for를 포함하고 access_log에 적용하십시오."
    },
    {
      "checkId": "3.2",
      "title": "로그 디렉터리 및 파일 권한 관리",
      "category": "3. 로그 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info",
          "params": { "path": "/var/log/nginx" },
          "as": "ld" },
        { "op": "assert.le", "params": { "value": "$ld.mode", "threshold": "0755" } },
        { "op": "assert.equals", "params": { "value": "$ld.worldWritable", "expected": false } },
        { "op": "assert.equals", "params": { "value": "$ld.groupWritable", "expected": false } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "로그 디렉터리와 파일의 소유자를 root 또는 전용 계정으로 제한하고 group/other 쓰기 권한을 제거하십시오. (디렉터리 755 이하, 파일 644 이하)"
    },
    {
      "checkId": "3.3",
      "title": "로그 파일 주기적 백업",
      "category": "3. 로그 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review",
          "params": { "detail": "로그 파일의 백업 정책(별도 로그 서버, filebeat, SIP Agent, logrotate 등) 존재 및 주기적 백업 수행 여부는 조직 통제/외부 수집기 설정에 의존하므로 자동 판정 불가. 중앙 수집기 프로세스와 백업 설정 파일에서 Nginx 로그 경로 수집 여부를 수동 확인하십시오." },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "별도 로그 서버, filebeat, SIP Agent, logrotate 등으로 로그 백업 정책을 구성하고 보존 주기를 확인하십시오."
    },
    {
      "checkId": "4.1",
      "title": "안정화 버전 및 패치 적용",
      "category": "4. 보안 패치",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review",
          "params": { "detail": "nginx -V 결과와 패키지 업데이트 이력만으로는 Nginx Security Advisories 및 배포판 백포트 패치 상태를 확정할 수 없어 자동 판정 불가. 설치 버전을 Nginx 보안 권고 기준으로 대조하여 취약 버전 여부를 수동 확인하십시오." },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "nginx -V 결과와 패키지 업데이트 이력을 확인하고 Nginx Security Advisories 기준으로 취약 버전이면 안정화 버전으로 업데이트하십시오."
    }
  ]
}
