{
  "packId": "kisa-linux",
  "title": "KISA 주요정보통신기반시설 Linux 서버 취약점 점검",
  "version": "1.0",
  "target": { "kind": ["os"], "product": "linux" },
  "vars": {},
  "requires": ["/etc/passwd"],
  "checks": [
    {
      "checkId": "1.1",
      "title": "root 계정 원격 접속 제한",
      "category": "1. 계정관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "config.sshd", "params": { "key": "PermitRootLogin", "default": "prohibit-password" }, "as": "r" },
        { "op": "assert.matches", "params": { "value": "$r.value", "regex": "(?i)^(no|prohibit-password)$" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "/etc/ssh/sshd_config 에서 PermitRootLogin 을 no 또는 prohibit-password 로 설정 후 sshd 재시작."
    },
    {
      "checkId": "1.2",
      "title": "불필요 계정 삭제",
      "category": "1. 계정관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review", "params": { "detail": "lp, uucp, nuucp 등 기본 불필요 계정 및 퇴직자 계정의 존재 여부는 조직의 계정 관리 정책과 대조가 필요하여 자동 판정 불가. 불필요/퇴직자 계정 삭제 또는 비활성화 여부를 수동 확인." } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "userdel 로 불필요 계정 삭제, 또는 shell 을 /sbin/nologin 으로 변경하여 로그인 차단."
    },
    {
      "checkId": "1.3",
      "title": "패스워드 복잡성 설정",
      "category": "1. 계정관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "config.read_value", "params": { "path": "/etc/security/pwquality.conf", "format": "properties", "key": "minclass" }, "as": "r" },
        { "op": "assert.ge", "params": { "value": "$r.value", "threshold": "4" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "/etc/security/pwquality.conf 에 minclass=4 (또는 dcredit/ucredit/lcredit/ocredit=-1) 설정으로 대/소문자·숫자·특수문자 혼합을 강제."
    },
    {
      "checkId": "1.4",
      "title": "패스워드 최소 길이 설정",
      "category": "1. 계정관리",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "config.read_value", "params": { "path": "/etc/security/pwquality.conf", "format": "properties", "key": "minlen" }, "as": "r" },
        { "op": "assert.ge", "params": { "value": "$r.value", "threshold": "8" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "/etc/security/pwquality.conf 에 minlen=8 이상 설정."
    },
    {
      "checkId": "1.5",
      "title": "패스워드 최대 사용기간 설정",
      "category": "1. 계정관리",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "config.read_value", "params": { "path": "/etc/login.defs", "format": "properties", "key": "PASS_MAX_DAYS" }, "as": "r" },
        { "op": "assert.le", "params": { "value": "$r.value", "threshold": "90" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "/etc/login.defs 에 PASS_MAX_DAYS 90 이하로 설정."
    },
    {
      "checkId": "1.6",
      "title": "패스워드 최소 사용기간 설정",
      "category": "1. 계정관리",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "config.read_value", "params": { "path": "/etc/login.defs", "format": "properties", "key": "PASS_MIN_DAYS" }, "as": "r" },
        { "op": "assert.ge", "params": { "value": "$r.value", "threshold": "1" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "/etc/login.defs 에 PASS_MIN_DAYS 1 이상으로 설정."
    },
    {
      "checkId": "1.7",
      "title": "계정 잠금 임계값 설정",
      "category": "1. 계정관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "config.pam", "params": { "files": ["/etc/pam.d/system-auth", "/etc/pam.d/password-auth"], "module": "pam_faillock.so", "rule": "present" } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "PAM 에 pam_faillock.so (deny=5, unlock_time=300 이상) 를 설정하여 로그인 실패 시 계정 잠금."
    },
    {
      "checkId": "1.8",
      "title": "패스워드 암호화 설정",
      "category": "1. 계정관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "sys.accounts", "params": { "rule": "password_algo", "expect_algo": "sha512" } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "/etc/login.defs 의 ENCRYPT_METHOD 를 SHA512 로 설정하고 패스워드 재설정."
    },
    {
      "checkId": "1.9",
      "title": "root UID 권한 관리",
      "category": "1. 계정관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "sys.accounts", "params": { "rule": "uid0_unique" } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "UID 0 은 root 계정만 갖도록 /etc/passwd 를 수정."
    },
    {
      "checkId": "1.10",
      "title": "동일한 UID 금지",
      "category": "1. 계정관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "sys.accounts", "params": { "rule": "duplicate_uid" } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "중복 UID 를 갖는 계정에 고유한 UID 를 부여."
    },
    {
      "checkId": "1.11",
      "title": "SU 제한",
      "category": "1. 계정관리",
      "severity": "low",
      "reference": { "kisaRisk": "하" },
      "method": "ops",
      "steps": [
        { "op": "config.pam", "params": { "files": ["/etc/pam.d/su"], "module": "pam_wheel.so", "rule": "present" } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "/etc/pam.d/su 에 pam_wheel.so 를 활성화하여 wheel 그룹 사용자만 su 사용 허용."
    },
    {
      "checkId": "1.12",
      "title": "shell 제한",
      "category": "1. 계정관리",
      "severity": "low",
      "reference": { "kisaRisk": "하" },
      "method": "ops",
      "steps": [
        { "op": "sys.accounts", "params": { "rule": "login_shell" } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "로그인이 불필요한 시스템 계정의 shell 을 /sbin/nologin 또는 /bin/false 로 변경."
    },
    {
      "checkId": "1.13",
      "title": "Session Timeout 설정",
      "category": "1. 계정관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "sys.shell_var", "params": { "files": ["/etc/profile", "/etc/bashrc", "/etc/profile.d/*.sh"], "key": "TMOUT", "rule": "num_le", "threshold": "1800" } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "/etc/profile 등에 TMOUT=1800 이하로 설정하여 세션 자동 종료."
    },
    {
      "checkId": "2.1",
      "title": "PATH 환경변수 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review", "params": { "detail": "root 계정 환경변수 파일의 PATH 에 현재 디렉토리(.)가 없거나 맨 뒤에만 위치하는지는 사용자별 환경파일 해석이 필요하여 수동 확인. root 의 .bash_profile/.profile 및 /etc/profile 의 PATH 를 점검." } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "PATH 환경변수에서 현재 디렉토리(.)를 제거하거나 맨 뒤로 이동."
    },
    {
      "checkId": "2.2",
      "title": "Passwd 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/passwd" }, "as": "r" },
        { "op": "assert.equals", "params": { "value": "$r.owner", "expected": "root" } },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0644" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/passwd; chmod 644 /etc/passwd"
    },
    {
      "checkId": "2.3",
      "title": "Shadow 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/shadow" }, "as": "r" },
        { "op": "assert.equals", "params": { "value": "$r.owner", "expected": "root" } },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0400" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/shadow; chmod 400 /etc/shadow"
    },
    {
      "checkId": "2.4",
      "title": "Group 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/group" }, "as": "r" },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0644" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/group; chmod 644 /etc/group (소유자 root 또는 bin)"
    },
    {
      "checkId": "2.5",
      "title": "Hosts 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/hosts" }, "as": "r" },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0644" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/hosts; chmod 644 /etc/hosts (소유자 root 또는 bin)"
    },
    {
      "checkId": "2.6",
      "title": "xinetd.conf 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/xinetd.conf" }, "as": "r" },
        { "op": "assert.equals", "params": { "value": "$r.owner", "expected": "root" } },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0640" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/xinetd.conf; chmod 640 /etc/xinetd.conf"
    },
    {
      "checkId": "2.7",
      "title": "(r)syslog.conf 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/rsyslog.conf" }, "as": "r" },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0640" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/rsyslog.conf; chmod 640 /etc/rsyslog.conf (소유자 root/bin/daemon)"
    },
    {
      "checkId": "2.8",
      "title": "서비스 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/services" }, "as": "r" },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0644" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/services; chmod 644 /etc/services (소유자 root 또는 bin)"
    },
    {
      "checkId": "2.9",
      "title": "Profile 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/profile" }, "as": "r" },
        { "op": "assert.equals", "params": { "value": "$r.worldWritable", "expected": false } },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0644" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/profile; chmod 644 /etc/profile (타 사용자 쓰기권한 제거)"
    },
    {
      "checkId": "2.10",
      "title": "Issue 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/issue" }, "as": "r" },
        { "op": "assert.equals", "params": { "value": "$r.worldWritable", "expected": false } },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0644" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "chown root /etc/issue; chmod 644 /etc/issue (타 사용자 쓰기권한 제거)"
    },
    {
      "checkId": "2.11",
      "title": "hosts.lpd 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "low",
      "reference": { "kisaRisk": "하" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/hosts.lpd" }, "as": "r" },
        { "op": "assert.equals", "params": { "value": "$r.owner", "expected": "root" } },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0600" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "/etc/hosts.lpd 삭제 또는 chown root; chmod 600 /etc/hosts.lpd (파일 부재 시 양호)"
    },
    {
      "checkId": "2.12",
      "title": "주요 디렉터리 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review", "params": { "detail": "/etc, /bin, /sbin, /usr/bin, /usr/sbin 등 주요 디렉터리(심볼릭 링크 대응 포함)의 소유자·권한을 다수 대상으로 순회 점검해야 하므로 수동 확인. 각 디렉터리에 타 사용자 쓰기권한이 없는지 점검." } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "주요 시스템 디렉터리의 소유자를 root 로, 타 사용자 쓰기권한을 제거."
    },
    {
      "checkId": "2.13",
      "title": "로컬 로그인용 PAM 규칙 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/pam.d/login" }, "as": "r" },
        { "op": "assert.equals", "params": { "value": "$r.worldWritable", "expected": false } },
        { "op": "assert.le", "params": { "value": "$r.mode", "threshold": "0644" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "/etc/pam.d 하위 로그인 규칙 파일의 소유자를 root/bin, group/other 쓰기권한 제거."
    },
    {
      "checkId": "2.14",
      "title": "홈 디렉터리 권한설정",
      "category": "2. 파일시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review", "params": { "detail": "전체 사용자 홈 디렉터리를 순회하며 소유자 일치 및 타 사용자 쓰기권한 여부를 점검해야 하므로 수동 확인. 각 홈 디렉터리가 해당 사용자 소유이고 group/other 쓰기권한이 없는지 점검." } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "각 사용자 홈 디렉터리의 소유자를 해당 사용자로 설정하고 타 사용자 쓰기권한 제거."
    },
    {
      "checkId": "2.15",
      "title": "홈 디렉터리의 존재 및 일치 여부 관리",
      "category": "2. 파일시스템",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review", "params": { "detail": "/etc/passwd 에 지정된 홈 디렉터리의 실제 존재 여부 및 일치성을 계정별로 순회 확인해야 하므로 수동 확인." } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "존재하지 않거나 부적절한 홈 디렉터리 경로를 수정하고 필요한 디렉터리를 생성."
    },
    {
      "checkId": "2.16",
      "title": "홈디렉터리 환경변수 파일 권한 설정",
      "category": "2. 파일시스템",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review", "params": { "detail": "각 사용자 홈 디렉터리의 환경변수 파일(.profile, .bashrc, .bash_profile 등)을 순회하며 소유자·권한을 점검해야 하므로 수동 확인." } }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "홈 디렉터리 환경변수 파일의 소유자를 해당 사용자로, 타 사용자 쓰기권한을 제거."
    },
    {
