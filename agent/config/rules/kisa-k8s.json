{
  "packId": "kisa-k8s",
  "title": "KISA 기준 Kubernetes 보안 점검",
  "version": "1.0",
  "target": { "kind": ["orchestrator"], "product": "kubernetes" },
  "vars": {},
  "requires": [],

  "checks": [
    {
      "checkId": "1.1",
      "title": "kubectl 사용자 관리",
      "category": "1. 계정 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/root/.kube/config" }, "as": "cfg" },
        { "op": "assert.le", "params": { "value": "$cfg.mode", "threshold": "0600" } },
        { "op": "fs.file_info", "params": { "path": "/root/.kube" }, "as": "dir" },
        { "op": "assert.le", "params": { "value": "$dir.mode", "threshold": "0755" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "권한 없는 계정의 kubeconfig를 삭제하고, 필요한 경우 .kube 디렉터리 755 이하 및 config 600 이하로 제한하십시오."
    },
    {
      "checkId": "2.1",
      "title": "설정 파일 권한",
      "category": "2. 파일 시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.file_info", "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml" }, "as": "api" },
        { "op": "assert.le", "params": { "value": "$api.mode", "threshold": "0644" } },
        { "op": "assert.equals", "params": { "value": "$api.owner", "expected": "root" } },
        { "op": "assert.equals", "params": { "value": "$api.group", "expected": "root" } },
        { "op": "fs.file_info", "params": { "path": "/etc/kubernetes/manifests/kube-controller-manager.yaml" }, "as": "cm" },
        { "op": "assert.le", "params": { "value": "$cm.mode", "threshold": "0644" } },
        { "op": "assert.equals", "params": { "value": "$cm.owner", "expected": "root" } },
        { "op": "assert.equals", "params": { "value": "$cm.group", "expected": "root" } },
        { "op": "fs.file_info", "params": { "path": "/etc/kubernetes/manifests/kube-scheduler.yaml" }, "as": "sc" },
        { "op": "assert.le", "params": { "value": "$sc.mode", "threshold": "0644" } },
        { "op": "assert.equals", "params": { "value": "$sc.owner", "expected": "root" } },
        { "op": "assert.equals", "params": { "value": "$sc.group", "expected": "root" } },
        { "op": "fs.file_info", "params": { "path": "/etc/kubernetes/manifests/etcd.yaml" }, "as": "etcd" },
        { "op": "assert.le", "params": { "value": "$etcd.mode", "threshold": "0644" } },
        { "op": "assert.equals", "params": { "value": "$etcd.owner", "expected": "root" } },
        { "op": "assert.equals", "params": { "value": "$etcd.group", "expected": "root" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "Kubernetes 설정 파일 소유자를 root:root로 제한하고 권한을 644 이하로 관리하십시오."
    },
    {
      "checkId": "2.2",
      "title": "데이터 디렉터리 권한",
      "category": "2. 파일 시스템",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "config.read_value",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "format": "regex", "pattern": "--data-dir=(\\S+)" },
          "as": "dd" },
        { "op": "fs.file_info", "params": { "path": "$dd.value" }, "as": "di" },
        { "op": "assert.le", "params": { "value": "$di.mode", "threshold": "0700" } },
        { "op": "assert.equals", "params": { "value": "$di.owner", "expected": "root" } },
        { "op": "assert.equals", "params": { "value": "$di.group", "expected": "root" } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "etcd 데이터 디렉터리 소유자를 root:root로 제한하고 권한을 700 이하로 관리하십시오."
    },
    {
      "checkId": "3.1",
      "title": "API 서버 인증 제어",
      "category": "3. 보안 설정",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--anonymous-auth=false", "is_regex": false },
          "as": "anon" },
        { "op": "assert.ge", "params": { "value": "$anon.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--insecure-port=[1-9]", "is_regex": true },
          "as": "insec" },
        { "op": "assert.le", "params": { "value": "$insec.count", "threshold": 0 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--service-account-lookup=true", "is_regex": false },
          "as": "sal" },
        { "op": "assert.ge", "params": { "value": "$sal.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--basic-auth-file", "is_regex": false },
          "as": "baf" },
        { "op": "assert.le", "params": { "value": "$baf.count", "threshold": 0 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--token-auth-file", "is_regex": false },
          "as": "taf" },
        { "op": "assert.le", "params": { "value": "$taf.count", "threshold": 0 } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "kube-apiserver에서 anonymous-auth=false, insecure-port=0, service-account-lookup=true를 적용하고 basic-auth-file/token-auth-file 사용을 제거하십시오."
    },
    {
      "checkId": "3.2",
      "title": "API Server 권한 제어",
      "category": "3. 보안 설정",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--authorization-mode=[^\\n]*RBAC", "is_regex": true },
          "as": "rbac" },
        { "op": "assert.ge", "params": { "value": "$rbac.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--authorization-mode=[^\\n]*Node", "is_regex": true },
          "as": "node" },
        { "op": "assert.ge", "params": { "value": "$node.count", "threshold": 1 } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "kube-apiserver authorization-mode에 Node,RBAC를 포함하여 최소 권한 기반 접근 제어를 적용하십시오."
    },
    {
      "checkId": "3.3",
      "title": "Admission Control 설정",
      "category": "3. 보안 설정",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "AlwaysAdmit", "is_regex": false },
          "as": "aa" },
        { "op": "assert.le", "params": { "value": "$aa.count", "threshold": 0 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--enable-admission-plugins=[^\\n]*NodeRestriction", "is_regex": true },
          "as": "nr" },
        { "op": "assert.ge", "params": { "value": "$nr.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--disable-admission-plugins=[^\\n]*ServiceAccount", "is_regex": true },
          "as": "sa" },
        { "op": "assert.le", "params": { "value": "$sa.count", "threshold": 0 } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "AlwaysAdmit을 제거하고 NodeRestriction을 활성화하며 ServiceAccount Admission 플러그인이 비활성화되지 않도록 설정하십시오."
    },
    {
      "checkId": "3.4",
      "title": "Controller Manager 설정",
      "category": "3. 보안 설정",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-controller-manager.yaml", "pattern": "--use-service-account-credentials=true", "is_regex": false },
          "as": "cred" },
        { "op": "assert.ge", "params": { "value": "$cred.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-controller-manager.yaml", "pattern": "--service-account-private-key-file", "is_regex": false },
          "as": "pkey" },
        { "op": "assert.ge", "params": { "value": "$pkey.count", "threshold": 1 } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "kube-controller-manager에 use-service-account-credentials=true 및 service-account-private-key-file을 설정하십시오."
    },
    {
      "checkId": "4.1",
      "title": "네트워크 SSL/TLS 적용",
      "category": "4. SSL/TLS 설정",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--kubelet-https=false", "is_regex": false },
          "as": "khttps" },
        { "op": "assert.le", "params": { "value": "$khttps.count", "threshold": 0 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--secure-port=0", "is_regex": false },
          "as": "sport" },
        { "op": "assert.le", "params": { "value": "$sport.count", "threshold": 0 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--kubelet-client-certificate", "is_regex": false },
          "as": "kcc" },
        { "op": "assert.ge", "params": { "value": "$kcc.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--kubelet-client-key", "is_regex": false },
          "as": "kck" },
        { "op": "assert.ge", "params": { "value": "$kck.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--service-account-key-file", "is_regex": false },
          "as": "sakf" },
        { "op": "assert.ge", "params": { "value": "$sakf.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--tls-cert-file", "is_regex": false },
          "as": "tcf" },
        { "op": "assert.ge", "params": { "value": "$tcf.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--tls-private-key-file", "is_regex": false },
          "as": "tpkf" },
        { "op": "assert.ge", "params": { "value": "$tpkf.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--client-ca-file", "is_regex": false },
          "as": "ccf" },
        { "op": "assert.ge", "params": { "value": "$ccf.count", "threshold": 1 } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "kube-apiserver에 kubelet client 인증서, service account key, TLS 인증서 및 client CA 설정을 적용하십시오."
    },
    {
      "checkId": "4.2",
      "title": "클라이언트 SSL/TLS 적용",
      "category": "4. SSL/TLS 설정",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review",
          "params": { "detail": "kube-controller-manager의 root-ca-file, cluster-signing-cert-file, cluster-signing-key-file 및 kubelet 인증서 rotation(RotateKubeletServerCertificate) 정책은 manifest 정적 확인만으로 최종 양호/취약을 확정할 수 없습니다. 실제 kubelet 서버 인증서 rotation 적용, CSR 승인 정책, 인증서 만료/갱신 운영 절차를 별도 확인해야 합니다." },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "kube-controller-manager의 root-ca-file, cluster-signing-cert-file, cluster-signing-key-file 및 kubelet 인증서 rotation 정책을 확인하고, CSR 승인 및 인증서 갱신 운영 절차를 점검하십시오."
    },
    {
      "checkId": "4.3",
      "title": "etcd SSL/TLS 적용",
      "category": "4. SSL/TLS 설정",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--client-cert-auth=true", "is_regex": false },
          "as": "cca" },
        { "op": "assert.ge", "params": { "value": "$cca.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--peer-client-cert-auth=true", "is_regex": false },
          "as": "pcca" },
        { "op": "assert.ge", "params": { "value": "$pcca.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--cert-file", "is_regex": false },
          "as": "cf" },
        { "op": "assert.ge", "params": { "value": "$cf.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--key-file", "is_regex": false },
          "as": "kf" },
        { "op": "assert.ge", "params": { "value": "$kf.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--peer-cert-file", "is_regex": false },
          "as": "pcf" },
        { "op": "assert.ge", "params": { "value": "$pcf.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--peer-key-file", "is_regex": false },
          "as": "pkf" },
        { "op": "assert.ge", "params": { "value": "$pkf.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--trusted-ca-file", "is_regex": false },
          "as": "tca" },
        { "op": "assert.ge", "params": { "value": "$tca.count", "threshold": 1 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--auto-tls=true", "is_regex": false },
          "as": "at" },
        { "op": "assert.le", "params": { "value": "$at.count", "threshold": 0 } },
        { "op": "fs.search_in_file",
          "params": { "path": "/etc/kubernetes/manifests/etcd.yaml", "pattern": "--peer-auto-tls=true", "is_regex": false },
          "as": "pat" },
        { "op": "assert.le", "params": { "value": "$pat.count", "threshold": 0 } }
      ],
      "pass": { "rule": "all_asserts_passed" },
      "remediation": "etcd manifest에 client-cert-auth, peer-client-cert-auth 및 인증서 파일 설정을 적용하고 auto-tls 사용을 제거하십시오."
    },
    {
      "checkId": "5.1",
      "title": "로그 설정",
      "category": "5. 로그 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review",
          "params": { "detail": "Kubernetes 로그 디렉터리/파일 권한 점검은 kubelet 런타임(--log-dir) 및 컨테이너 런타임 로그 경로(/var/log/containers, /var/log/pods 등)에 의존하여 오프라인 정적 점검으로 확정할 수 없습니다. 로그 디렉터리 소유자 root:root 및 권한(디렉터리 755 이하, 파일 644 이하) 여부를 운영 환경에서 직접 확인해야 합니다." },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "Kubernetes 로그 디렉터리와 파일 소유자를 root:root로 제한하고 권한을 디렉터리 755 이하, 파일 644 이하로 관리하십시오."
    },
    {
      "checkId": "5.2",
      "title": "로그파일 주기적 백업",
      "category": "5. 로그 관리",
      "severity": "high",
      "reference": { "kisaRisk": "상" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review",
          "params": { "detail": "로그 파일 주기적 백업 여부는 Filebeat/Elastic Agent/SIP Agent/Alloy 등 로그 수집·백업 에이전트의 실행 상태와 설정(대상 로그 경로 포함 여부, 백업 주기·보관 정책)에 의존하므로 정적 점검으로 확정할 수 없습니다. 로그 수집/백업 설정에 Kubernetes 로그 디렉터리와 파일이 포함되어 있는지 별도 확인이 필요합니다." },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "Filebeat, SIP Agent, Elastic Agent, Alloy 등 로그 수집/백업 설정에 Kubernetes 로그 디렉터리와 파일을 포함하고 백업 주기 및 보관 정책을 확인하십시오."
    },
    {
      "checkId": "6.1",
      "title": "최신 보안 패치 적용",
      "category": "6. 보안 패치",
      "severity": "medium",
      "reference": { "kisaRisk": "중" },
      "method": "ops",
      "steps": [
        { "op": "ctx.review",
          "params": { "detail": "Kubernetes 최신 보안 패치 적용 여부는 설치 버전(kubelet/kubectl version), 공식 릴리스/EOL 정책(https://kubernetes.io/releases/) 및 배포판·벤더 백포트 지원 여부를 종합적으로 확인해야 하므로 오프라인 정적 점검만으로 확정할 수 없습니다. 유지보수 종료(EOL) 마이너 버전 사용 시 취약하며, 최신 안정화 버전 유지 및 보안 권고 적용 여부를 확인해야 합니다." },
          "as": "r" }
      ],
      "pass": { "rule": "op_verdict" },
      "remediation": "kubectl/kubelet version, 패키지 업데이트 이력, Kubernetes 보안 권고 및 배포판/벤더 백포트 기준을 확인하고 취약 버전이면 업데이트하십시오."
    }
  ]
}
